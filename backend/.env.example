SECRET_KEY=django-insecure-change-this-in-production-replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
DB_NAME=gestion_rectificaciones
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS - Frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email (usar console.EmailBackend para desarrollo, SMTP para producción)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=app-password-aqui
DEFAULT_FROM_EMAIL=GNARC <noreply@gestora.bo>
